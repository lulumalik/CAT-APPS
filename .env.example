APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --- S3-compatible storage (Cloudflare R2, AWS S3, Laravel Object Storage) ---
# When these four are set, uploads default to the "s3" disk (persistent, not lost on redeploy).
# AWS_DEFAULT_REGION=auto is mapped to us-east-1 for the PHP SDK when AWS_ENDPOINT is set (R2).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
# Public bucket / custom domain for Storage::url() (R2 public URL or r2.dev / your CDN)
# AWS_URL=https://your-bucket.your-subdomain.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional: force disk ("public" | "s3" | custom disk name). If unset, auto when AWS_* complete.
# UPLOAD_FILESYSTEM_DISK=s3
# REGISTRATION_FILESYSTEM_DISK=s3

# Onboarding: defaults to same rules as UPLOAD / AWS. Use REGISTRATION_FILESYSTEM_DISK=public for local-only files.
# REGISTRATION_USE_SIGNED_URLS=true
# REGISTRATION_SIGNED_URL_TTL_HOURS=168

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
