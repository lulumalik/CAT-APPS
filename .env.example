APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# --- S3-compatible storage (Cloudflare R2, AWS S3, Laravel Object Storage) ---
# When AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_BUCKET, and AWS_ENDPOINT are set,
# config defaults registration + uploads to the "s3" disk (see config/filesystems.php).
#
# R2 shape (replace placeholders; never commit real keys):
#   AWS_DEFAULT_REGION=auto
#   AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   AWS_BUCKET=<bucket-name>
#   AWS_USE_PATH_STYLE_ENDPOINT=false
# Set AWS_URL to your bucket’s public base URL so files open on R2/CDN, not /storage on APP_URL.
# Examples: https://pub-<hash>.r2.dev  or  https://files.yourdomain.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Filesystem disk for uploads/onboarding ("public" recommended for VPS local storage).
UPLOAD_FILESYSTEM_DISK=public
REGISTRATION_FILESYSTEM_DISK=public

# Onboarding: defaults to same rules as UPLOAD / AWS. Use REGISTRATION_FILESYSTEM_DISK=public for local-only files.
# REGISTRATION_USE_SIGNED_URLS=true
# REGISTRATION_SIGNED_URL_TTL_HOURS=168

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_ENCRYPTION=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
