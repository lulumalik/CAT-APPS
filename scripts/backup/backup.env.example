BACKUP_ROOT=/opt/backups/cat-apps

# PostgreSQL container details
DB_CONTAINER_NAME=postgresql-database-xxxx
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me

# Optional additional args, example:
# DB_DUMP_EXTRA_ARGS=--no-owner --no-privileges
DB_DUMP_EXTRA_ARGS=

# Host directory path that stores Laravel uploaded files.
# Point this to your Docker volume mount for /var/www/html/storage.
STORAGE_SOURCE_DIR=/data/cat-apps/storage

# Delete backups older than this value (days)
RETENTION_DAYS=14
